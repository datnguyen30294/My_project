# Hostname được coi là platform (ví dụ production: service360.demego.vn).
# Mọi hostname khác mà kết thúc bằng `.${NUXT_PUBLIC_BASE_DOMAIN}` sẽ được coi là tenant.
NUXT_PUBLIC_PLATFORM_DOMAIN=localhost
# Base domain dùng để tách tenant slug khỏi hostname (ví dụ: demego.vn).
NUXT_PUBLIC_BASE_DOMAIN=localhost
# Fallback API URL — được dùng khi không suy được từ hostname (SSR bên trong Docker, local dev).
NUXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NUXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
