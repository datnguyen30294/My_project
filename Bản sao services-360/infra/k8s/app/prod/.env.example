# Docker Hub
DOCKERHUB_USERNAME=your-dockerhub-username
DOCKERHUB_TOKEN=dckr_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxx
REGISTRY_IMAGE=${DOCKERHUB_USERNAME}/residential

# Laravel
APP_KEY=base64:xxxxx
DB_PASSWORD=secret

# S3 / MinIO
AWS_ACCESS_KEY_ID=xxxxx
AWS_SECRET_ACCESS_KEY=xxxxx
AWS_ENDPOINT=https://minio.example.com

# Frontend
# Platform FE hostname — request đến host này = platform; mọi host khác = tenant.
NUXT_PUBLIC_PLATFORM_DOMAIN=service360.demego.vn
# Base domain để strip tenant slug khỏi hostname (chỉ cho filter display).
NUXT_PUBLIC_BASE_DOMAIN=demego.vn
# Fallback URL khi không suy được từ hostname (hiếm ở prod).
NUXT_PUBLIC_API_URL=https://api.service360.demego.vn/api/v1
# URL nội bộ để SSR trong pod gọi BE qua k8s Service DNS (bỏ qua ingress).
NUXT_API_INTERNAL_URL=http://backend/api/v1

# Mail (Gmail SMTP — use Google App Password, not your login password)
MAIL_USERNAME=your.gmail@gmail.com
MAIL_PASSWORD=xxxx xxxx xxxx xxxx

RESIMART_DB_PASSWORD=
